@model IEnumerable<apteka.Models.Proiz>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Naz)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Naz)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.IDPr">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.IDPr">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.IDPr">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
